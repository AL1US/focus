#!/bin/bash

# --- КОНФИГУРАЦИЯ ---
HOSTS_FILE="/etc/hosts"
CONF_FILE="/etc/focus.conf"
MARKER_START="# --- FOCUS START ---"
MARKER_END="# --- FOCUS END ---"
BIN_PATH="/usr/local/bin/focus"

if [ "$EUID" -ne 0 ]; then
    printf "Error: Please run this script as root (sudo).\n"
    printf "Ошибка: Эту утилиту нужно запускать с правами sudo.\n"
    exit 1
fi

if [ ! -f "$CONF_FILE" ]; then
    echo "LANG=ru" > "$CONF_FILE"
fi
source "$CONF_FILE"

# --- ЛОКАЛИЗАЦИЯ ---
if [ "$LANG" == "en" ]; then
    MSG_NO_SITE="Specify a site. Example: focus add youtube.com"
    MSG_EXISTS="Site %s is already in the list."
    MSG_ADDED="Site %s added to the blacklist."
    MSG_REMOVED="Site %s removed."
    MSG_LIST_TITLE="Current blacklist:"
    MSG_UNLOCKED="Sites unlocked for %s minute(s)."
    MSG_UNBLOCKED_FOREVER="Sites unlocked permanently."
    MSG_TIME_LEFT="Time left: "
    MSG_TIME_UP="Time is up. Sites are blocked again."
    MSG_INTERRUPTED="Timer interrupted! Blocking sites back..."
    MSG_BLOCKED_ALL="All sites from the list are forcibly blocked."
    MSG_SCHED_SET="Schedule set: block at %s, unblock at %s (Mon-Fri)."
    MSG_SCHED_CLEARED="Schedule cleared."
    MSG_SCHED_ERR="Time format must be HH:MM. Example: focus schedule 09:00 15:00"
    
    HELP_USAGE="Usage: sudo focus [command] [arguments]"
    HELP_CMDS="Commands:"
    HELP_ADD="  add <domain>             - Add site to blocklist"
    HELP_REMOVE="  remove <domain>          - Remove site from blocklist"
    HELP_LIST="  list                     - Show blocked sites"
    HELP_BLOCK="  block                    - Force block sites right now"
    HELP_UNBLOCK="  unblock                  - Unblock sites permanently"
    HELP_UNLOCK="  unlock [minutes]         - Unlock sites with a timer (default 5 min)"
    HELP_SCHED="  schedule <start> <end>   - Set weekday schedule (e.g., 09:00 15:00)"
    HELP_UNSCHED="  unschedule               - Remove active schedule"
    HELP_LANG="  lang <ru|en>             - Change language"
    HELP_CMD="  help                     - Show this help message"
else
    MSG_NO_SITE="Укажите сайт. Пример: focus add youtube.com"
    MSG_EXISTS="Сайт %s уже в списке."
    MSG_ADDED="Сайт %s добавлен в черный список."
    MSG_REMOVED="Сайт %s удален."
    MSG_LIST_TITLE="Текущий черный список:"
    MSG_UNLOCKED="Сайты разблокированы на %s минут(ы)."
    MSG_UNBLOCKED_FOREVER="Сайты разблокированы бессрочно."
    MSG_TIME_LEFT="Осталось: "
    MSG_TIME_UP="Время вышло. Сайты снова заблокированы."
    MSG_INTERRUPTED="Таймер прерван! Блокирую сайты обратно..."
    MSG_BLOCKED_ALL="Все сайты из списка принудительно заблокированы."
    MSG_SCHED_SET="Расписание установлено: блокировка в %s, разблокировка в %s (Пн-Пт)."
    MSG_SCHED_CLEARED="Расписание удалено."
    MSG_SCHED_ERR="Формат времени должен быть ЧЧ:ММ. Пример: focus schedule 09:00 15:00"
    
    HELP_USAGE="Использование: sudo focus [команда] [аргументы]"
    HELP_CMDS="Команды:"
    HELP_ADD="  add <домен>              - Добавить сайт в блокировку"
    HELP_REMOVE="  remove <домен>           - Удалить сайт"
    HELP_LIST="  list                     - Показать список сайтов"
    HELP_BLOCK="  block                    - Принудительно заблокировать сайты прямо сейчас"
    HELP_UNBLOCK="  unblock                  - Разблокировать сайты бессрочно"
    HELP_UNLOCK="  unlock [минуты]          - Разблокировать на время (по умолчанию 5 мин)"
    HELP_SCHED="  schedule <старт> <конец> - Блокировка по будням (напр., 09:00 15:00)"
    HELP_UNSCHED="  unschedule               - Удалить расписание"
    HELP_LANG="  lang <ru|en>             - Изменить язык"
    HELP_CMD="  help                     - Показать эту справку"
fi

if ! grep -q "$MARKER_START" "$HOSTS_FILE"; then
    printf "\n%s\n%s\n" "$MARKER_START" "$MARKER_END" >> "$HOSTS_FILE"
fi

sed_in_place() {
    if [ "$(uname -s)" = "Darwin" ]; then
        sed -i '' "$@"
    else
        sed -i "$@"
    fi
}

block_sites() {
    sed_in_place "/$MARKER_START/,/$MARKER_END/ s/^#*[[:space:]]*127\.0\.0\.1/127.0.0.1/" "$HOSTS_FILE"
}

unblock_sites() {
    sed_in_place "/$MARKER_START/,/$MARKER_END/ s/^127\.0\.0\.1/# 127.0.0.1/" "$HOSTS_FILE"
}

case "$1" in
    add)
        if [ -z "$2" ]; then printf "%s\n" "$MSG_NO_SITE"; exit 1; fi
        DOMAIN=$(printf "%s" "$2" | sed -e 's|^[^/]*//||' -e 's|/.*||')
        if sed -n "/$MARKER_START/,/$MARKER_END/p" "$HOSTS_FILE" | grep -q "$DOMAIN"; then
            printf "${MSG_EXISTS}\n" "$DOMAIN"
        else
            awk -v site="127.0.0.1 $DOMAIN" -v marker="$MARKER_END" '$0 == marker {print site; print $0; next} {print}' "$HOSTS_FILE" > /tmp/hosts.tmp && cp /tmp/hosts.tmp "$HOSTS_FILE"
            rm -f /tmp/hosts.tmp
            printf "${MSG_ADDED}\n" "$DOMAIN"
        fi
        ;;
    
    remove)
        if [ -z "$2" ]; then printf "%s\n" "$MSG_NO_SITE"; exit 1; fi
        DOMAIN=$(printf "%s" "$2" | sed -e 's|^[^/]*//||' -e 's|/.*||')
        sed_in_place "/$MARKER_START/,/$MARKER_END/ { /$DOMAIN/d; }" "$HOSTS_FILE"
        printf "${MSG_REMOVED}\n" "$DOMAIN"
        ;;
    
    list)
        printf "%s\n" "$MSG_LIST_TITLE"
        sed -n "/$MARKER_START/,/$MARKER_END/p" "$HOSTS_FILE" | grep "127.0.0.1" | sed 's/^#*[[:space:]]*127\.0\.0\.1 //' | awk '{print "- " $1}'
        ;;

    block)
        block_sites
        printf "\033[31m%s\033[0m\n" "$MSG_BLOCKED_ALL"
        ;;

    unblock)
        unblock_sites
        printf "\033[32m%s\033[0m\n" "$MSG_UNBLOCKED_FOREVER"
        ;;

    unlock)
        MINUTES=${2:-5}
        START_TIME=$(date +%s)
        TOTAL_SEC=$((MINUTES * 60))
        END_TIME=$((START_TIME + TOTAL_SEC))
        
        stty -echo
        tput civis
        
        trap "stty echo; tput cnorm; printf '\n\033[31m%s\033[0m\n' \"$MSG_INTERRUPTED\"; block_sites; exit" INT

        unblock_sites
        
        printf "\033[32m${MSG_UNLOCKED}\033[0m\n" "$MINUTES"
        
        FULL_BAR="██████████████████████████████"
        EMPTY_BAR="░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░"
        
        while [ $(date +%s) -lt $END_TIME ]; do
            NOW=$(date +%s)
            REMAINING=$((END_TIME - NOW))
            ELAPSED=$((NOW - START_TIME))
            
            H=$((REMAINING / 3600))
            M=$(((REMAINING % 3600) / 60))
            S=$((REMAINING % 60))
            TIME_FMT=$(printf "%02d:%02d:%02d" $H $M $S)
            
            if [ "$TOTAL_SEC" -gt 0 ]; then
                FILLED=$(( (ELAPSED * 30) / TOTAL_SEC ))
            else
                FILLED=30
            fi
            EMPTY=$(( 30 - FILLED ))
            
            BAR="${FULL_BAR:0:FILLED}${EMPTY_BAR:0:EMPTY}"
            
            printf "\r\033[2K%s\033[36m[%s]\033[0m %s" "$MSG_TIME_LEFT" "$BAR" "$TIME_FMT"
            
            sleep 1
        done
        
        stty echo
        tput cnorm
        
        printf "\n\033[31m%s\033[0m\n" "$MSG_TIME_UP"
        block_sites
        ;;

    schedule)
        START_TIME=$2
        END_TIME=$3
        if [[ ! "$START_TIME" =~ ^[0-9]{2}:[0-9]{2}$ ]] || [[ ! "$END_TIME" =~ ^[0-9]{2}:[0-9]{2}$ ]]; then
            printf "%s\n" "$MSG_SCHED_ERR"
            exit 1
        fi
        S_H=${START_TIME%:*} ; S_M=${START_TIME#*:}
        E_H=${END_TIME%:*} ; E_M=${END_TIME#*:}

        crontab -l 2>/dev/null | grep -v "$BIN_PATH" > /tmp/cron.tmp || true
        echo "$S_M $S_H * * 1-5 $BIN_PATH block >/dev/null 2>&1" >> /tmp/cron.tmp
        echo "$E_M $E_H * * 1-5 $BIN_PATH unblock >/dev/null 2>&1" >> /tmp/cron.tmp
        crontab /tmp/cron.tmp
        rm -f /tmp/cron.tmp
        printf "${MSG_SCHED_SET}\n" "$START_TIME" "$END_TIME"
        ;;

    unschedule)
        crontab -l 2>/dev/null | grep -v "$BIN_PATH" | crontab -
        printf "%s\n" "$MSG_SCHED_CLEARED"
        ;;

    lang)
        if [[ "$2" == "en" || "$2" == "ru" ]]; then
            echo "LANG=$2" > "$CONF_FILE"
            source "$CONF_FILE"
            if [ "$LANG" == "en" ]; then printf "Language changed to English.\n"; else printf "Язык изменен на Русский.\n"; fi
        else
            printf "Error: Use 'ru' or 'en'. / Ошибка: Используйте 'ru' или 'en'.\n"
        fi
        ;;

    help|*)
        echo "$HELP_USAGE"
        echo "$HELP_CMDS"
        echo "$HELP_ADD"
        echo "$HELP_REMOVE"
        echo "$HELP_LIST"
        echo "$HELP_BLOCK"
        echo "$HELP_UNBLOCK"
        echo "$HELP_UNLOCK"
        echo "$HELP_SCHED"
        echo "$HELP_UNSCHED"
        echo "$HELP_LANG"
        echo "$HELP_CMD"
        ;;
esac
